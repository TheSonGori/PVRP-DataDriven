@article{EKSIOGLU20091472,
    title = {The vehicle routing problem: A taxonomic review},
    journal = {Computers & Industrial Engineering},
    volume = {57},
    number = {4},
    pages = {1472-1483},
    year = {2009},
    issn = {0360-8352},
    doi = {https://doi.org/10.1016/j.cie.2009.05.009},
    url = {https://www.sciencedirect.com/science/article/pii/S0360835209001405},
    author = {Burak Eksioglu and Arif Volkan Vural and Arnold Reisman},
    keywords = {Routing, Vehicle routing, VRP, Taxonomy, Classification},
    abstract = {This paper presents a methodology for classifying the literature of the Vehicle Routing Problem (VRP). VRP as a field of study and practice is defined quite broadly. It is considered to encompass all of the managerial, physical, geographical, and informational considerations as well as the theoretic disciplines impacting this ever emerging-field. Over its lifespan the VRP literature has become quite disjointed and disparate. Keeping track of its development has become difficult because its subject matter transcends several academic disciplines and professions that range from algorithm design to traffic management. Consequently, this paper defines VRP’s domain in its entirety, accomplishes an all-encompassing taxonomy for the VRP literature, and delineates all of VRP’s facets in a parsimonious and discriminating manner. Sample articles chosen for their disparity are classified to illustrate the descriptive power and parsimony of the taxonomy. Moreover, all previously published VRP taxonomies are shown to be relatively myopic; that is, they are subsumed by what is herein presented. Because the VRP literature encompasses esoteric and highly theoretical articles at one extremum and descriptions of actual applications at the other, the article sampling includes the entire range of the VRP literature.}
}

@article{HEMMELMAYR2009791,
    title = {A variable neighborhood search heuristic for periodic routing problems},
    journal = {European Journal of Operational Research},
    volume = {195},
    number = {3},
    pages = {791-802},
    year = {2009},
    issn = {0377-2217},
    doi = {https://doi.org/10.1016/j.ejor.2007.08.048},
    url = {https://www.sciencedirect.com/science/article/pii/S0377221707011034},
    author = {Vera C. Hemmelmayr and Karl F. Doerner and Richard F. Hartl},
    keywords = {Periodic vehicle routing problem, Periodic traveling salesman problem, Metaheuristics, Variable neighborhood search},
    abstract = {The aim of this paper is to propose a new heuristic for the Periodic Vehicle Routing Problem (PVRP) without time windows. The PVRP extends the classical Vehicle Routing Problem (VRP) to a planning horizon of several days. Each customer requires a certain number of visits within this time horizon while there is some flexibility on the exact days of the visits. Hence, one has to choose the visit days for each customer and to solve a VRP for each day. Our method is based on Variable Neighborhood Search (VNS). Computational results are presented, that show that our approach is competitive and even outperforms existing solution procedures proposed in the literature. Also considered is the special case of a single vehicle, i.e. the Periodic Traveling Salesman Problem (PTSP). It is shown that slight changes of the proposed VNS procedure is also competitive for the PTSP.}
}

